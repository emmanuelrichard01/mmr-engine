{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Reconciliation Match Rate",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "reconciliation_match_rate_percent",
          "legendFormat": "Match Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          },
          "unit": "percent",
          "min": 90,
          "max": 100
        }
      }
    },
    {
      "title": "Open Exposure (NGN)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "reconciliation_open_exposure_ngn",
          "legendFormat": "Exposure"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 100000 },
              { "color": "red", "value": 500000 }
            ]
          },
          "unit": "currencyNGN"
        }
      }
    },
    {
      "title": "Webhook Ingestion Rate",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(webhook_events_received_total[5m])",
          "legendFormat": "{{ psp }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Discrepancies by Type",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "reconciliation_discrepancies_total",
          "legendFormat": "{{ type }}"
        }
      ]
    },
    {
      "title": "API Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "{{ path }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Pipeline Processing Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "targets": [
        {
          "expr": "rate(pipeline_processing_seconds_sum[5m]) / rate(pipeline_processing_seconds_count[5m])",
          "legendFormat": "{{ flow }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Rate Limit Rejections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate(rate_limit_rejected_total[5m]))",
          "legendFormat": "Rejected/sec"
        }
      ]
    },
    {
      "title": "Auth Failures",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate(auth_failures_total[5m]))",
          "legendFormat": "Auth Fail/sec"
        }
      ]
    },
    {
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "kafka_consumer_lag",
          "legendFormat": "{{ topic }}"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["mmr", "reconciliation"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "title": "MMR Reconciliation Engine",
  "uid": "mmr-dashboard"
}
